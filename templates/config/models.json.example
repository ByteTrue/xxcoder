{
  "default_backend": "codex",
  "default_model": "gpt-5.3-codex",
  "wrapper": {
    "timeout_ms": 1200000,
    "no_output_timeout_ms": 900000,
    "backend_no_output_timeout_ms": {
      "opencode": 90000
    },
    "keep_logs": false
  },
  "backends": {
    "codex": {
      "base_url": "",
      "api_key": ""
    },
    "claude": {
      "base_url": "",
      "api_key": ""
    },
    "gemini": {
      "base_url": "",
      "api_key": ""
    },
    "opencode": {
      "base_url": "",
      "api_key": ""
    }
  },
  "agents": {
    "oracle": {
      "backend": "codex",
      "model": "gpt-5.2",
      "prompt_file": "~/.codeagent/agents/oracle.md",
      "reasoning": "high",
      "disallowed_tools": ["write", "edit"]
    },
    "developer": {
      "backend": "codex",
      "model": "gpt-5.3-codex",
      "prompt_file": "~/.codeagent/agents/developer.md",
      "reasoning": "high"
    },
    "explorer": {
      "backend": "opencode",
      "model": "opencode/kimi-k2.5-free",
      "prompt_file": "~/.codeagent/agents/explorer.md",
      "disallowed_tools": ["write", "edit"]
    },
    "librarian": {
      "backend": "opencode",
      "model": "opencode/kimi-k2.5-free",
      "prompt_file": "~/.codeagent/agents/librarian.md",
      "disallowed_tools": ["write", "edit"]
    },
    "looker": {
      "backend": "gemini",
      "model": "gemini-3-flash",
      "prompt_file": "~/.codeagent/agents/looker.md",
      "disallowed_tools": ["write", "edit"]
    },
    "planner": {
      "backend": "codex",
      "model": "gpt-5.2",
      "prompt_file": "~/.codeagent/agents/planner.md",
      "disallowed_tools": ["write", "edit"]
    },
    "reviewer": {
      "backend": "codex",
      "model": "gpt-5.2",
      "prompt_file": "~/.codeagent/agents/reviewer.md",
      "reasoning": "medium",
      "disallowed_tools": ["write", "edit"]
    }
  }
}
